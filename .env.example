# EduPay Environment Configuration
# Copy this file to .env and update with your real values

# PostgreSQL connection string (DigitalOcean Managed Database)
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@host:25060/database?sslmode=require

# JSON Web Token secret - use a long random string in production
JWT_SECRET=your_secure_random_secret_key_here

# Server port
PORT=3000

# SMTP settings (required for password setup and email-based MFA)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@edupay.com

# MFA controls
MFA_TOKEN_TTL_MINUTES=10
MFA_MAX_ATTEMPTS=5

# Optional: override default seeded user accounts
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_FULL_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@edupay.com

SEED_HR_USERNAME=hr
SEED_HR_PASSWORD=hr123
SEED_HR_FULL_NAME=Default HR Manager
SEED_HR_EMAIL=hr@edupay.com

SEED_ACCOUNTANT_USERNAME=accountant
SEED_ACCOUNTANT_PASSWORD=accountant123
SEED_ACCOUNTANT_FULL_NAME=Default Accountant
SEED_ACCOUNTANT_EMAIL=accountant@edupay.com

SEED_TEACHER_USERNAME=teacher
SEED_TEACHER_PASSWORD=teacher123
SEED_TEACHER_FULL_NAME=Default Teacher
SEED_TEACHER_EMAIL=teacher@edupay.com
